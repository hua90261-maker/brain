import React, { useState, useEffect } from 'react';

export default function FreedomRoadBrain() {
  const [market, setMarket] = useState({ a50: '--', oil: '--', time: '...' });
  const [aiAnalysis, setAiAnalysis] = useState("正在扫描全球因果...");

  useEffect(() => {
    const scout = async () => {
      try {
        const res = await fetch('/api/data');
        const json = await res.json();
        setMarket(json);
        
        // 自动触发逻辑：如果油价高于 80 且没有分析过，自动触发 AI
        if (parseFloat(json.oil) > 80 && aiAnalysis.includes("扫描")) {
          askAI(`原油价格目前在 ${json.oil}，请分析是否受地缘战争驱动，并甄别消息真伪。`);
        }
      } catch (e) { console.log("侦察中断"); }
    };

    const askAI = async (q) => {
      const res = await fetch('/api/ai', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: q })
      });
      const data = await res.json();
      setAiAnalysis(data.analysis);
    };

    scout();
    const heartbeat = setInterval(scout, 5000); 
    return () => clearInterval(heartbeat);
  }, [aiAnalysis]);

  return (
    <div className="min-h-screen bg-black text-white p-4 font-sans leading-tight">
      <div className="rounded-3xl bg-slate-900 p-6 border-b-4 border-red-600 mb-4">
        <div className="flex justify-between text-[10px] mb-4 text-slate-500 font-bold tracking-widest">
          <span>SENSING LIVE: {market.time}</span>
          <span className="text-red-500">BATTLE MODE</span>
        </div>
        <div className="grid grid-cols-2 gap-4">
          <div><p className="text-[10px] opacity-50 uppercase">A50 Index</p><p className="text-4xl font-black italic">{market.a50}</p></div>
          <div className="text-right"><p className="text-[10px] opacity-50 uppercase">Crude Oil</p><p className="text-4xl font-black italic text-yellow-500">{market.oil}</p></div>
        </div>
      </div>

      <div className="bg-blue-950/20 border border-blue-900/40 rounded-3xl p-5">
        <h2 className="text-[10px] font-black text-blue-400 mb-3 tracking-[.3em] uppercase italic">参谋长·自动甄别报告</h2>
        <div className="bg-black/50 p-4 rounded-2xl border border-blue-900/10 min-h-[100px]">
          <p className="text-[11px] text-slate-300 leading-relaxed font-serif italic">
            {aiAnalysis}
          </p>
        </div>
      </div>
    </div>
  );
}
